# ─── FreightPulse Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# Neo4j (matches docker-compose defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092

# TimescaleDB (matches docker-compose defaults)
TIMESCALE_DATABASE_URL=postgresql://freightpulse:freightpulse123@localhost:5432/freightpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (LLM reasoning step — required for Step E)
ANTHROPIC_API_KEY=

# News ingestion — optional, falls back to GDELT (no key needed)
NEWS_API_KEY=

# Weather ingestion — optional, falls back to Open-Meteo (no key needed)
WEATHER_API_KEY=

# AIS data — optional, falls back to mock AIS generator if absent
AIS_API_KEY=

# Twilio — required for phone call step
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=     # Your Twilio number, e.g. +15551234567
USER_PHONE_NUMBER=       # The number to call for the demo, e.g. +919876543210

# TwiML callback base URL — set to your ngrok URL for local demo
# e.g. https://abc123.ngrok.io
# Required for Twilio to fetch TwiML when the call connects.
TWIML_BASE_URL=http://localhost:8000
